  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Management API auth token. Pass as Bearer token in Authorization header or as ?token= query parameter for WebSocket endpoints."
      }
    },
    "schemas": {
      "Client": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid", "description": "Unique client identifier" },
          "name": { "type": "string", "description": "Human-readable client name" },
          "enabled": { "type": "boolean", "description": "Whether the client is allowed to connect" },
          "tags": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Optional tags for client organization"
          }
        }
      },
      "Connection": {
        "type": "object",
        "properties": {
          "session_id": { "type": "string", "description": "Unique session identifier" },
          "client_id": { "type": "string", "format": "uuid" },
          "client_name": { "type": "string" },
          "remote_addr": { "type": "string", "description": "Client IP address" },
          "target": { "type": "string", "description": "Destination address" },
          "transport": { "type": "string", "description": "Transport protocol used" },
          "bytes_sent": { "type": "integer" },
          "bytes_received": { "type": "integer" },
          "connected_at": { "type": "string", "format": "date-time" },
          "duration_secs": { "type": "integer" }
        }
      },
      "Route": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "description": "Unique rule identifier" },
          "name": { "type": "string", "description": "Human-readable rule name" },
          "condition": { "type": "string", "description": "Match condition (e.g., DomainMatch:*.ads.*, IpCidr:10.0.0.0/8, PortRange:80-443, All)" },
          "action": { "type": "string", "enum": ["allow", "block"], "description": "Action to take when condition matches" },
          "priority": { "type": "integer", "description": "Rule priority (lower = higher priority)" }
        }
      },
      "Forward": {
        "type": "object",
        "properties": {
          "listen_port": { "type": "integer", "description": "Local port to listen on" },
          "target": { "type": "string", "description": "Target address (host:port)" },
          "protocol": { "type": "string", "enum": ["tcp", "udp"], "description": "Protocol for forwarding" }
        }
      },
      "Permissions": {
        "type": "object",
        "description": "Client permission set controlling what actions the client can perform",
        "properties": {
          "allow_tcp": { "type": "boolean", "default": true },
          "allow_udp": { "type": "boolean", "default": true },
          "max_connections": { "type": "integer", "description": "Maximum concurrent connections (0 = unlimited)" },
          "allowed_domains": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Domain whitelist (empty = allow all)"
          },
          "blocked_domains": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Domain blacklist"
          }
        }
      }
    }
  },
  "tags": [
    { "name": "Health", "description": "Health checks, metrics, and system information" },
    { "name": "Connections", "description": "Active connection management and monitoring" },
    { "name": "Clients", "description": "Client CRUD, permissions, and sharing" },
    { "name": "Bandwidth", "description": "Bandwidth limits and traffic quotas" },
    { "name": "Metrics", "description": "Per-client metrics and history" },
    { "name": "Config", "description": "Server configuration management and backups" },
    { "name": "Forwards", "description": "Port forwarding rules" },
    { "name": "Routes", "description": "Routing and access control rules" },
    { "name": "ACLs", "description": "Access control lists for clients" },
    { "name": "Alerts", "description": "Alert thresholds and notifications" },
    { "name": "WebSocket", "description": "Real-time streaming endpoints" }
  ]
}
