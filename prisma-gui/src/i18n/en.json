    "help": {
      "transport": "The protocol used to carry data between your device and the server. QUIC is fastest, WebSocket works through CDNs, TCP is the most compatible.",
      "cipher": "Encryption algorithm for the tunnel. ChaCha20 is fast on mobile, AES-GCM benefits from hardware acceleration on most CPUs.",
      "skipCertVerify": "Disables TLS certificate checking. Only use this for testing — in production it allows man-in-the-middle attacks.",
      "tlsOnTcp": "Adds a TLS layer around the TCP transport. Enable this when your server expects TLS wrapping on plain TCP connections.",
      "alpn": "Application-Layer Protocol Negotiation. Tells the server which protocols you support. Common values: h2, http/1.1.",
      "sniSlicing": "Splits the SNI (Server Name Indication) across multiple TLS records to evade DPI that reads the first record only.",
      "salamander": "Obfuscates UDP packets with a pre-shared password, making them look like random noise to firewalls.",
      "portHopping": "Periodically switches the server port to evade per-port throttling or blocking.",
      "xmux": "Multiplexes multiple logical streams over fewer physical connections, reducing handshake overhead.",
      "trafficShaping": "Adds padding, jitter, or dummy packets to disguise traffic patterns from statistical analysis.",
      "fec": "Adds redundant data shards so lost packets can be recovered without retransmission. Increases bandwidth usage.",
      "tun": "Creates a virtual network adapter that captures all system traffic, routing it through the proxy tunnel.",
      "dnsMode": "Controls how DNS queries are resolved. 'Tunnel' sends queries through the proxy. 'Fake-IP' assigns local IPs to avoid DNS leaks.",
      "routingRules": "JSON rules that control which traffic goes through the proxy (PROXY), bypasses it (DIRECT), or is blocked (REJECT)."
    }
